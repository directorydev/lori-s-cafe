<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainContainer" prefHeight="800.0" prefWidth="1280.0" styleClass="main-bg" stylesheets="@application.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.DashboardController">
   <top>
      <VBox styleClass="main-header" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER" styleClass="top-header">
               <children>
                  <VBox alignment="CENTER_LEFT" spacing="2.0">
                     <children>
                        <Label styleClass="header-title" text="Lori's Taste Cafe" />
                        <Label styleClass="header-subtitle" text="Point of Sale System" />
                     </children>
                  </VBox>
                  <Pane HBox.hgrow="ALWAYS" />
                  <HBox alignment="CENTER_RIGHT" spacing="15.0">
                     <children>
                        <Label fx:id="dateTimeLabel" styleClass="header-subtitle" text="Loading Date..." />
                        <Button onAction="#handleLogout" styleClass="secondary-btn" text="Logout" />
                     </children>
                  </HBox>
               </children>
            </HBox>
            
            <HBox alignment="CENTER" spacing="10.0" styleClass="main-nav-bar">
               <children>
                  <HBox alignment="CENTER" spacing="5.0" styleClass="pill-nav-container">
                     <children>
                        <ToggleButton fx:id="dashboardToggle" mnemonicParsing="false" onAction="#showDashboard" selected="true" styleClass="nav-pill" text="Dashboard">
                           <toggleGroup>
                              <ToggleGroup fx:id="mainNavToggleGroup" />
                           </toggleGroup>
                        </ToggleButton>
                        <ToggleButton fx:id="inventoryToggle" mnemonicParsing="false" onAction="#showInventory" styleClass="nav-pill" text="Inventory" toggleGroup="$mainNavToggleGroup" />
                        <ToggleButton fx:id="ordersToggle" mnemonicParsing="false" onAction="#showOrders" styleClass="nav-pill" text="Orders" toggleGroup="$mainNavToggleGroup" />
                        <ToggleButton fx:id="analyticsToggle" mnemonicParsing="false" onAction="#handleAnalytics" styleClass="nav-pill" text="Analytics" toggleGroup="$mainNavToggleGroup" />
                        <ToggleButton fx:id="settingsToggle" mnemonicParsing="false" onAction="#handleSettings" styleClass="nav-pill" text="Logs" toggleGroup="$mainNavToggleGroup" />
                     </children>
                  </HBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   
   <center>
      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent;" vbarPolicy="ALWAYS" BorderPane.alignment="CENTER">
         <content>
            <VBox fx:id="dashboardContentArea" spacing="30.0" styleClass="page-container">
               <children>
                  
                  <HBox spacing="20.0">
                     <children>
                        <VBox onMouseClicked="#handleStartSale" alignment="CENTER_LEFT" prefWidth="300.0" spacing="15.0" styleClass="kpi-card, kpi-blue-border" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
                           <children>
                              <HBox alignment="TOP_LEFT" spacing="10.0">
                                 <children>
                                    <Label style="-fx-text-fill: #3b82f6; -fx-font-weight: bold;" text="New Order" />
                                    <Pane HBox.hgrow="ALWAYS" />
                                    <Label style="-fx-font-size: 20px;" text="🛒" />
                                 </children>
                              </HBox>
                              <Label styleClass="kpi-value-blue" text="Start Sale" />
                              <Label styleClass="card-description" text="Create new order" />
                           </children>
                        </VBox>
                        
                        <VBox onMouseClicked="#handleCardInventory" prefWidth="300.0" spacing="15.0" styleClass="kpi-card, kpi-green-border" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
                           <children>
                              <HBox alignment="TOP_LEFT" spacing="10.0">
                                 <children>
                                    <Label style="-fx-text-fill: #10b981; -fx-font-weight: bold;" text="Inventory" />
                                    <Pane HBox.hgrow="ALWAYS" />
                                    <Label style="-fx-font-size: 20px;" text="📦" />
                                 </children>
                              </HBox>
                              <Label fx:id="totalInventoryLabel" styleClass="kpi-value-green" text="0" />
                              <Label styleClass="card-description" text="Items in stock" />
                           </children>
                        </VBox>
                        
                        <VBox prefWidth="300.0" spacing="15.0" styleClass="kpi-card, kpi-purple-border" HBox.hgrow="ALWAYS">
                           <children>
                              <HBox alignment="TOP_LEFT" spacing="10.0">
                                 <children>
                                    <Label style="-fx-text-fill: #8b5cf6; -fx-font-weight: bold;" text="Today's Sales" />
                                    <Pane HBox.hgrow="ALWAYS" />
                                    <Label style="-fx-font-size: 20px;" text="📈" />
                                 </children>
                              </HBox>
                              <Label fx:id="todaySalesLabel" styleClass="kpi-value-purple" text="₱0.00" />
                              <Label styleClass="card-description" text="Live revenue tracking" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <HBox spacing="20.0">
                     <children>
                        <VBox onMouseClicked="#handleCardOrders" prefWidth="300.0" spacing="15.0" styleClass="kpi-card, kpi-orange-border" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
                           <children>
                              <HBox alignment="TOP_LEFT" spacing="10.0">
                                 <children>
                                    <Label style="-fx-text-fill: #f97316; -fx-font-weight: bold;" text="Orders" />
                                    <Pane HBox.hgrow="ALWAYS" />
                                    <Label style="-fx-font-size: 20px;" text="🧾" />
                                 </children>
                              </HBox>
                              <Label fx:id="todayOrdersLabel" styleClass="kpi-value-orange" text="0" />
                              <Label styleClass="card-description" text="Orders today" />
                           </children>
                        </VBox>
                        
                        <VBox onMouseClicked="#handleCardLogs" prefWidth="300.0" spacing="15.0" styleClass="kpi-card, kpi-blue-border" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
                           <children>
                              <HBox alignment="TOP_LEFT" spacing="10.0">
                                 <children>
                                    <Label style="-fx-text-fill: #3b82f6; -fx-font-weight: bold;" text="Master Logs" />
                                    <Pane HBox.hgrow="ALWAYS" />
                                    <Label style="-fx-font-size: 20px;" text="🛡️" />
                                 </children>
                              </HBox>
                              <Label styleClass="kpi-value-blue" style="-fx-font-size: 22px;" text="System Audit Trail" />
                              <Label styleClass="card-description" text="Track all global system events" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>