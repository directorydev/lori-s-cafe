<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" style="-fx-background-color: white;" stylesheets="@application.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.MenuController">
   <children>
      <HBox alignment="CENTER_LEFT" spacing="20.0">
         <children>
            <Label styleClass="title-label" text="Menu Management" />
            <TextField fx:id="searchField" prefWidth="300.0" promptText="Search items..." styleClass="modern-text-field" />
         </children>
      </HBox>
      
      <HBox spacing="20.0" VBox.vgrow="ALWAYS">
         <children>
            <TableView fx:id="menuTable" HBox.hgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colName" prefWidth="250.0" text="Item Name" />
                <TableColumn fx:id="colCategory" prefWidth="150.0" text="Category" />
                <TableColumn fx:id="colPrice" prefWidth="100.0" text="Price (PHP)" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            
            <VBox prefWidth="320.0" spacing="20.0" styleClass="add-item-panel">
               <children>
                  <Label text="Add New Item">
                     <font><Font name="System Bold" size="18.0" /></font>
                  </Label>
                  
                  <VBox alignment="CENTER" spacing="10.0" styleClass="image-upload-container">
                     <children>
                        <StackPane prefHeight="150.0" prefWidth="200.0" style="-fx-background-color: #f9f9f9; -fx-background-radius: 10;">
                           <children>
                              <ImageView fx:id="itemImagePreview" fitHeight="140.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                              <Label fx:id="placeholderLabel" text="No Image Selected" textFill="#999" />
                           </children>
                        </StackPane>
                        <Button mnemonicParsing="false" onAction="#handleUploadImage" styleClass="button-outline" text="Upload Image" />
                     </children>
                  </VBox>

                  <TextField fx:id="nameInput" prefHeight="40.0" promptText="Item Name" styleClass="modern-text-field" />
                  
                  <ComboBox fx:id="categoryComboBox" maxWidth="Infinity" prefHeight="40.0" promptText="Select Category" styleClass="modern-combo-box" />
                  
                  <TextField fx:id="priceInput" prefHeight="40.0" promptText="Price (PHP)" styleClass="modern-text-field" />
                  
                  <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                     <children>
                        <Button maxWidth="Infinity" mnemonicParsing="true" onAction="#addItem" prefHeight="45.0" text="Add to Menu" />
                        <Button maxWidth="Infinity" mnemonicParsing="true" onAction="#deleteItem" styleClass="delete-button" text="Delete Selected" />
                     </children>
                     <padding>
                        <Insets top="10.0" />
                     </padding>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </VBox>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
</VBox>