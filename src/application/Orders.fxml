<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" styleClass="page-container" stylesheets="@application.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.OrdersController">
   <children>
      
      <HBox alignment="CENTER_LEFT">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-padding: 5 10; -fx-background-radius: 8px; -fx-font-size: 18px;" text="💲" />
                  <VBox spacing="2.0">
                     <children>
                        <Label styleClass="header-title" style="-fx-text-fill: #6d28d9;" text="Order Management" />
                        <Label styleClass="header-subtitle" text="Track and manage all Lori's Taste Cafe orders" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <Pane HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" styleClass="secondary-btn" text="📥 Export Data" />
                  <Button mnemonicParsing="false" onAction="#refreshData" styleClass="secondary-btn" text="🔄 Refresh" />
               </children>
            </HBox>
         </children>
      </HBox>

      <HBox spacing="15.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="kpi-card-horizontal, kpi-blue-border" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="kpi-icon-blue" text="🛒" />
                  <VBox alignment="CENTER_LEFT">
                     <children>
                        <Label styleClass="kpi-title" text="Total Orders" />
                        <Label fx:id="totalOrdersLabel" styleClass="kpi-value-blue" text="0" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="kpi-card-horizontal, kpi-green-border" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="kpi-icon-green" text="💲" />
                  <VBox alignment="CENTER_LEFT">
                     <children>
                        <Label styleClass="kpi-title" text="Total Revenue" />
                        <Label fx:id="totalRevenueLabel" styleClass="kpi-value-green" text="₱0.00" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="kpi-card-horizontal, kpi-purple-border" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="kpi-icon-purple" text="📈" />
                  <VBox alignment="CENTER_LEFT">
                     <children>
                        <Label styleClass="kpi-title" text="Avg Order Value" />
                        <Label fx:id="avgOrderValueLabel" styleClass="kpi-value-purple" text="₱0.00" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="kpi-card-horizontal, kpi-orange-border" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="kpi-icon-orange" text="✓" />
                  <VBox alignment="CENTER_LEFT">
                     <children>
                        <Label styleClass="kpi-title" text="Completed" />
                        <Label fx:id="completedOrdersLabel" styleClass="kpi-value-orange" text="0" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </HBox>

      <HBox alignment="CENTER_LEFT" spacing="15.0">
         <children>
            <TextField fx:id="searchField" promptText="Search by order number, customer, or cashier..." styleClass="search-bar-gray" HBox.hgrow="ALWAYS" />
            <ComboBox fx:id="statusCombo" prefWidth="130.0" promptText="All Status" styleClass="custom-input" />
            <ComboBox fx:id="paymentCombo" prefWidth="130.0" promptText="All Payments" styleClass="custom-input" />
            <ComboBox fx:id="timeCombo" prefWidth="130.0" promptText="All Time" styleClass="custom-input" />
         </children>
      </HBox>

      <TableView fx:id="ordersTable" styleClass="clean-table" VBox.vgrow="ALWAYS">
        <placeholder>
            <VBox alignment="CENTER" spacing="10.0">
                <Label style="-fx-font-size: 48px; -fx-text-fill: #9ca3af;" text="🧾" />
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="No orders found" />
                <Label style="-fx-text-fill: #6b7280;" text="Orders will appear here once you start making sales through the POS system" />
            </VBox>
        </placeholder>
        <columns>
          <TableColumn fx:id="colOrderId" prefWidth="120.0" text="Order ID" reorderable="false" />
          <TableColumn fx:id="colDate" prefWidth="150.0" text="Date &amp; Time" reorderable="false" />
          <TableColumn fx:id="colCustomer" prefWidth="150.0" text="Customer" reorderable="false" />
          <TableColumn fx:id="colTotal" prefWidth="120.0" text="Total Amount" reorderable="false" />
          <TableColumn fx:id="colPayment" prefWidth="120.0" text="Payment Method" reorderable="false" />
          <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status" reorderable="false" />
          <TableColumn fx:id="colAction" prefWidth="100.0" text="Action" reorderable="false" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>

   </children>
</VBox>