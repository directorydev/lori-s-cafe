<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" style="-fx-background-color: #f4f6f8; -fx-padding: 30;" stylesheets="@application.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.OrdersController">
   <children>
      
      <HBox alignment="CENTER_LEFT" spacing="20.0">
         <children>
            <VBox>
               <children>
                  <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Order Management" />
                  <Label style="-fx-font-size: 14px; -fx-text-fill: #6b7280;" text="View all transactions, monitor live sales, and approve void requests" />
               </children>
            </VBox>
            <Pane HBox.hgrow="ALWAYS" />
            <ComboBox fx:id="statusFilterCombo" prefWidth="180.0" promptText="Filter by Status" style="-fx-font-size: 14px; -fx-padding: 5; -fx-background-radius: 6; -fx-background-color: white; -fx-border-color: #d1d5db; -fx-border-radius: 6;" />
            <Button onAction="#loadOrders" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 6; -fx-cursor: hand;" text="↻ Refresh List" />
         </children>
      </HBox>

      <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #e5e7eb; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);" VBox.vgrow="ALWAYS">
         <children>
            <TableView fx:id="ordersTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px; -fx-selection-bar: #eff6ff;">
              <columns>
                <TableColumn fx:id="colId" prefWidth="80.0" text="Order ID" />
                <TableColumn fx:id="colDate" prefWidth="200.0" text="Date &amp; Time" />
                  <TableColumn fx:id="colCashier" prefWidth="150.0" text="Cashier" />
                  <TableColumn fx:id="colTotal" prefWidth="120.0" text="Total Amount" />
                  <TableColumn fx:id="colPayment" prefWidth="120.0" text="Payment" />
                  <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>

      <HBox alignment="CENTER_RIGHT" spacing="15.0">
         <children>
            <Button onAction="#handleViewDetails" style="-fx-background-color: #4b5563; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 6; -fx-cursor: hand;" text="📄 View Receipt Details" />
            <Button onAction="#handleApproveVoid" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 6; -fx-cursor: hand;" text="🚫 Approve Void" />
         </children>
      </HBox>

   </children>
</VBox>