<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" styleClass="page-container" stylesheets="@application.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.InventoryController">
   <children>
      
      <HBox alignment="CENTER">
         <children>
            <HBox alignment="CENTER" styleClass="graph-nav-container">
               <children>
                  <ToggleButton fx:id="productTab" mnemonicParsing="false" selected="true" styleClass="graph-tab" text="📦 Products">
                     <toggleGroup>
                        <ToggleGroup fx:id="inventoryTabs" />
                     </toggleGroup>
                  </ToggleButton>
                  <ToggleButton fx:id="rawMaterialTab" mnemonicParsing="false" styleClass="graph-tab" text="🥛 Raw Materials" toggleGroup="$inventoryTabs" />
               </children>
            </HBox>
         </children>
      </HBox>

      <HBox alignment="CENTER_LEFT">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-padding: 5 10; -fx-background-radius: 8px; -fx-font-size: 18px;" text="📦" />
                  <VBox spacing="2.0">
                     <children>
                        <Label styleClass="header-title" style="-fx-text-fill: #065f46;" text="Inventory Management" />
                        <Label styleClass="header-subtitle" text="Lori's Taste Cafe products and stock levels" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <Pane HBox.hgrow="ALWAYS" />
            <Button fx:id="addItemBtn" mnemonicParsing="false" onAction="#handleAddItem" styleClass="primary-btn" text="+ Add Product" />
         </children>
      </HBox>

      <HBox spacing="15.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="kpi-card-horizontal, kpi-blue-border" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="kpi-icon-blue" text="📋" />
                  <VBox alignment="CENTER_LEFT">
                     <Label styleClass="kpi-title" text="Total Items" />
                     <Label fx:id="totalProductsLabel" styleClass="kpi-value-blue" text="0" />
                  </VBox>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="kpi-card-horizontal, kpi-green-border" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="kpi-icon-green" text="₱" />
                  <VBox alignment="CENTER_LEFT">
                     <Label styleClass="kpi-title" text="Total Value" />
                     <Label fx:id="totalValueLabel" styleClass="kpi-value-green" text="₱0" />
                  </VBox>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="kpi-card-horizontal, kpi-orange-border" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="kpi-icon-orange" text="⚠️" />
                  <VBox alignment="CENTER_LEFT">
                     <Label styleClass="kpi-title" text="Low Stock" />
                     <Label fx:id="lowStockLabel" styleClass="kpi-value-orange" text="0" />
                  </VBox>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="kpi-card-horizontal, kpi-purple-border" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="kpi-icon-purple" text="📊" />
                  <VBox alignment="CENTER_LEFT">
                     <Label styleClass="kpi-title" text="Avg Stock Level" />
                     <Label fx:id="avgStockLabel" styleClass="kpi-value-purple" text="0" />
                  </VBox>
               </children>
            </HBox>
         </children>
      </HBox>

      <HBox spacing="15.0" alignment="CENTER_LEFT">
         <children>
            <TextField fx:id="searchField" promptText="Search items..." styleClass="search-bar-gray" HBox.hgrow="ALWAYS" />
            <ComboBox fx:id="stockLevelCombo" prefWidth="180.0" promptText="All Stock Levels" styleClass="custom-input" />
            <ComboBox fx:id="categoryCombo" prefWidth="180.0" promptText="All Categories" styleClass="custom-input" />
         </children>
      </HBox>

      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #f4f4f5;" VBox.vgrow="ALWAYS">
         <content>
            <FlowPane fx:id="productGrid" hgap="20.0" vgap="20.0">
               <padding>
                  <Insets bottom="10.0" left="5.0" right="5.0" top="10.0" />
               </padding>
            </FlowPane>
         </content>
      </ScrollPane>
      
   </children>
</VBox>