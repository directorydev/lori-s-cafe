<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="400.0" stylesheets="@application.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.LoginController">
   <children>
      <VBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #f9fafb;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding><Insets bottom="50.0" left="50.0" right="50.0" top="50.0" /></padding>
         <children>
            <Label styleClass="header-label" text="Create Account" />
            <HBox spacing="10.0">
               <children>
                  <TextField fx:id="firstNameField" prefWidth="145.0" promptText="First Name" />
                  <TextField fx:id="lastNameField" prefWidth="145.0" promptText="Last Name" />
               </children>
            </HBox>
            <TextField fx:id="regUsernameField" promptText="Username" />
            <PasswordField fx:id="regPasswordField" promptText="Password" />
            <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" />
            <HBox spacing="15.0">
               <children>
                  <Button onAction="#handleRegisterSubmit" prefWidth="140.0" text="Confirm" />
                  <Button onAction="#handleCancel" prefWidth="140.0" styleClass="button-outline" text="Back" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>