<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" styleClass="page-container" stylesheets="@application.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.InventoryLogsController">
   <children>
      
      <HBox alignment="CENTER_LEFT">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label style="-fx-background-color: #111827; -fx-text-fill: white; -fx-padding: 5 10; -fx-background-radius: 8px; -fx-font-size: 18px;" text="逃" />
                  <VBox spacing="2.0">
                     <children>
                        <Label styleClass="header-title" text="Inventory Audit Logs" />
                        <Label styleClass="header-subtitle" text="Track all stock movements, accountability, and reference orders" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <Pane HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <Button fx:id="exportBtn" mnemonicParsing="false" onAction="#handleExportData" styleClass="secondary-btn" text="踏 Export Logs" />
               <Button fx:id="refreshBtn" mnemonicParsing="false" onAction="#refreshData" styleClass="secondary-btn" text="売 Refresh" />
            </HBox>
         </children>
      </HBox>

      <HBox spacing="15.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="kpi-card-horizontal, kpi-blue-border" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="kpi-icon-blue" text="投" />
                  <VBox alignment="CENTER_LEFT">
                     <children>
                        <Label styleClass="kpi-title" text="Total Movements" />
                        <Label fx:id="totalLogsLabel" styleClass="kpi-value-blue" text="0" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="kpi-card-horizontal, kpi-orange-border" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="kpi-icon-orange" text="悼" />
                  <VBox alignment="CENTER_LEFT">
                     <children>
                        <Label styleClass="kpi-title" text="Sale Deductions" />
                        <Label fx:id="totalDeductionsLabel" styleClass="kpi-value-orange" text="0" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="kpi-card-horizontal, kpi-green-border" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="kpi-icon-green" text="嶋" />
                  <VBox alignment="CENTER_LEFT">
                     <children>
                        <Label styleClass="kpi-title" text="Voids &amp; Returns" />
                        <Label fx:id="totalReturnsLabel" styleClass="kpi-value-green" text="0" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </HBox>

      <HBox alignment="CENTER_LEFT" spacing="15.0">
         <children>
            <TextField fx:id="searchField" prefWidth="280.0" promptText="🔍 Search Material, User, or Order #..." style="-fx-font-size: 14px; -fx-padding: 8; -fx-background-radius: 6; -fx-border-color: #d1d5db; -fx-border-radius: 6;" />
            <Pane HBox.hgrow="ALWAYS" />
            <ComboBox fx:id="typeCombo" prefWidth="200.0" promptText="All Log Types" styleClass="custom-input" />
            <ComboBox fx:id="timeCombo" prefWidth="150.0" promptText="All Time" styleClass="custom-input" />
         </children>
      </HBox>

      <TableView fx:id="logsTable" styleClass="clean-table" VBox.vgrow="ALWAYS">
        <placeholder>
            <VBox alignment="CENTER" spacing="10.0">
                <Label style="-fx-font-size: 48px; -fx-text-fill: #9ca3af;" text="搭" />
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="No logs recorded yet" />
                <Label style="-fx-text-fill: #6b7280;" text="Inventory movements will appear here automatically." />
            </VBox>
        </placeholder>
        <columns>
          <TableColumn fx:id="colLogId" prefWidth="80.0" text="Log ID" reorderable="false" />
          <TableColumn fx:id="colDate" prefWidth="180.0" text="Date &amp; Time" reorderable="false" />
          <TableColumn fx:id="colUser" prefWidth="120.0" text="User / Auth" reorderable="false" />
          <TableColumn fx:id="colMaterial" prefWidth="180.0" text="Raw Material" reorderable="false" />
          <TableColumn fx:id="colAmount" prefWidth="130.0" text="Amount" reorderable="false" />
          <TableColumn fx:id="colType" prefWidth="150.0" text="Movement Type" reorderable="false" />
          <TableColumn fx:id="colRef" prefWidth="100.0" text="Reference" reorderable="false" />
          <TableColumn fx:id="colRemarks" prefWidth="200.0" text="Remarks" reorderable="false" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>

   </children>
</VBox>