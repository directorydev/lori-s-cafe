<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" styleClass="main-bg" stylesheets="@application.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.InventoryController">
   <children>
      <Label fx:id="modalHeaderLabel" text="Add New Product" styleClass="header-title" />
      
      <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
          <Tab text="Details">
            <content>
              <VBox spacing="15.0" style="-fx-padding: 20;">
                 <children>
                    <VBox spacing="5.0">
                       <Label text="Product Name" styleClass="input-label" />
                       <TextField fx:id="nameInput" promptText="Enter product name" styleClass="custom-input" />
                    </VBox>
                    <HBox spacing="15.0">
                       <VBox HBox.hgrow="ALWAYS">
                          <Label text="Selling Price (₱)" styleClass="input-label" />
                          <TextField fx:id="priceInput" promptText="0.00" styleClass="custom-input" />
                       </VBox>
                       <VBox HBox.hgrow="ALWAYS">
                          <Label text="Cost Price (₱)" styleClass="input-label" />
                          <TextField fx:id="costInput" promptText="0.00" styleClass="custom-input" />
                       </VBox>
                    </HBox>
                    <VBox spacing="5.0">
                       <Label text="Stock Management" styleClass="input-label" />
                       <HBox spacing="15.0">
                          <TextField fx:id="stockInput" promptText="Current Stock" styleClass="custom-input" HBox.hgrow="ALWAYS" />
                          <TextField fx:id="minStockInput" promptText="Min. Stock" styleClass="custom-input" HBox.hgrow="ALWAYS" />
                       </HBox>
                    </VBox>
                 </children>
              </VBox>
            </content>
          </Tab>
          <Tab text="Ingredients">
             <content>
                <VBox spacing="10.0" style="-fx-padding: 20;">
                   <Label text="Select raw materials and quantities..." styleClass="header-subtitle" />
                   <!-- Placeholder for recipe connection logic -->
                   <ListView fx:id="ingredientSelectionList" prefHeight="200.0" />
                </VBox>
             </content>
          </Tab>
        </tabs>
      </TabPane>

      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button onAction="#handleCloseModal" styleClass="secondary-btn" text="Cancel" />
            <Button onAction="#saveNewProduct" styleClass="primary-btn" text="Add Product" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>
</VBox>