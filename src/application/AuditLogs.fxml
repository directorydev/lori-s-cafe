<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" styleClass="page-container" stylesheets="@application.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.AuditLogsController">
   <children>
      
      <HBox alignment="CENTER_LEFT">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label style="-fx-background-color: #111827; -fx-text-fill: white; -fx-padding: 5 10; -fx-background-radius: 8px; -fx-font-size: 18px;" text="🛡️" />
                  <VBox spacing="2.0">
                     <children>
                        <Label styleClass="header-title" text="Master Audit Logs" />
                        <Label styleClass="header-subtitle" text="Global system trail combining sales, transactions, and inventory events" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <Pane HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <Button fx:id="exportBtn" mnemonicParsing="false" onAction="#handleGenerateReport" styleClass="secondary-btn" text="📄 Generate Master Report" />
               <Button fx:id="refreshBtn" mnemonicParsing="false" onAction="#refreshData" styleClass="secondary-btn" text="↻ Refresh" />
            </HBox>
         </children>
      </HBox>

      <HBox spacing="15.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="kpi-card-horizontal, kpi-blue-border" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="kpi-icon-blue" text="📊" />
                  <VBox alignment="CENTER_LEFT">
                     <children>
                        <Label styleClass="kpi-title" text="Total System Events" />
                        <Label fx:id="totalLogsLabel" styleClass="kpi-value-blue" text="0" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="kpi-card-horizontal, kpi-green-border" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="kpi-icon-green" text="💰" />
                  <VBox alignment="CENTER_LEFT">
                     <children>
                        <Label styleClass="kpi-title" text="Sales / Transaction Events" />
                        <Label fx:id="totalSalesLabel" styleClass="kpi-value-green" text="0" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="kpi-card-horizontal, kpi-orange-border" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="kpi-icon-orange" text="📦" />
                  <VBox alignment="CENTER_LEFT">
                     <children>
                        <Label styleClass="kpi-title" text="Inventory Events" />
                        <Label fx:id="totalInventoryLabel" styleClass="kpi-value-orange" text="0" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </HBox>

      <HBox alignment="CENTER_LEFT" spacing="15.0">
         <children>
            <TextField fx:id="searchField" prefWidth="250.0" promptText="🔍 Search Details, User, or Order #..." style="-fx-font-size: 14px; -fx-padding: 8; -fx-background-radius: 6; -fx-border-color: #d1d5db; -fx-border-radius: 6;" />
            <Pane HBox.hgrow="ALWAYS" />
            <ComboBox fx:id="moduleCombo" prefWidth="180.0" promptText="All Modules" styleClass="custom-input" />
            <ComboBox fx:id="actionCombo" prefWidth="180.0" promptText="All Actions" styleClass="custom-input" />
            <ComboBox fx:id="timeCombo" prefWidth="130.0" promptText="All Time" styleClass="custom-input" />
         </children>
      </HBox>

      <TableView fx:id="logsTable" styleClass="clean-table" VBox.vgrow="ALWAYS">
        <placeholder>
            <VBox alignment="CENTER" spacing="10.0">
                <Label style="-fx-font-size: 48px; -fx-text-fill: #9ca3af;" text="📭" />
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="No system logs found" />
                <Label style="-fx-text-fill: #6b7280;" text="Actions taken in the POS will appear here." />
            </VBox>
        </placeholder>
        <columns>
          <TableColumn fx:id="colTraceId" prefWidth="100.0" text="Trace ID" reorderable="false" />
          <TableColumn fx:id="colDate" prefWidth="180.0" text="Date &amp; Time" reorderable="false" />
          <TableColumn fx:id="colModule" prefWidth="120.0" text="Module" reorderable="false" />
          <TableColumn fx:id="colAction" prefWidth="160.0" text="Event / Action" reorderable="false" />
          <TableColumn fx:id="colDetails" prefWidth="280.0" text="System Details" reorderable="false" />
          <TableColumn fx:id="colUser" prefWidth="150.0" text="Actor / User" reorderable="false" />
          <TableColumn fx:id="colRef" prefWidth="100.0" text="Reference" reorderable="false" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>

   </children>
</VBox>