<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootContainer" alignment="TOP_CENTER" prefWidth="400.0" spacing="5.0" styleClass="receipt-paper" stylesheets="@application.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.ReceiptModalController">
   <children>
      <Label styleClass="receipt-title" text="LORI'S TASTE CAFE" />
      <Label fx:id="lblAddress" styleClass="receipt-text" text="[ Cafe Address Goes Here ]" />
      <Label fx:id="lblPhone" styleClass="receipt-text" text="Tel: [ Contact Number ]" />
      
      <Label styleClass="receipt-dashed" text="----------------------------------------" />
      
      <VBox alignment="CENTER_LEFT" prefWidth="100.0" spacing="2.0">
         <children>
            <HBox>
               <Label styleClass="receipt-text" text="Order #:" />
               <Pane HBox.hgrow="ALWAYS" />
               <Label fx:id="lblOrderId" styleClass="receipt-text" text="000" />
            </HBox>
            <HBox>
               <Label styleClass="receipt-text" text="Date:" />
               <Pane HBox.hgrow="ALWAYS" />
               <Label fx:id="lblDate" styleClass="receipt-text" text="YYYY-MM-DD" />
            </HBox>
            <HBox>
               <Label styleClass="receipt-text" text="Cashier:" />
               <Pane HBox.hgrow="ALWAYS" />
               <Label fx:id="lblCashier" styleClass="receipt-text" text="Name" />
            </HBox>
            <HBox>
               <Label styleClass="receipt-text" text="Status:" />
               <Pane HBox.hgrow="ALWAYS" />
               <Label fx:id="lblStatus" styleClass="receipt-text, receipt-bold" text="Completed" />
            </HBox>
         </children>
      </VBox>
      
      <Label styleClass="receipt-dashed" text="----------------------------------------" />
      
      <HBox>
         <Label prefWidth="40.0" styleClass="receipt-text, receipt-bold" text="QTY" />
         <Label prefWidth="200.0" styleClass="receipt-text, receipt-bold" text="ITEM" />
         <Label alignment="CENTER_RIGHT" prefWidth="100.0" styleClass="receipt-text, receipt-bold" text="AMOUNT" HBox.hgrow="ALWAYS" />
      </HBox>
      
      <VBox fx:id="itemsContainer" spacing="3.0" />
      
      <Label styleClass="receipt-dashed" text="----------------------------------------" />
      
      <VBox spacing="5.0">
         <children>
            <HBox>
               <Label styleClass="receipt-text, receipt-bold" text="TOTAL DUE" />
               <Pane HBox.hgrow="ALWAYS" />
               <Label fx:id="lblTotal" styleClass="receipt-text, receipt-bold" text="₱0.00" />
            </HBox>
            <HBox>
               <Label fx:id="lblPaymentMethod" styleClass="receipt-text" text="PAYMENT (Cash)" />
               <Pane HBox.hgrow="ALWAYS" />
               <Label fx:id="lblPaymentAmount" styleClass="receipt-text" text="₱0.00" />
            </HBox>
         </children>
      </VBox>
      
      <Label styleClass="receipt-dashed" text="----------------------------------------" />
      
      <Label styleClass="receipt-text" text="Thank you, quench your thirst!" />
      <Label styleClass="receipt-text" text="and satisfy your cravings!" />
      
      <Label styleClass="receipt-dashed" text="----------------------------------------" />
      
      <Button fx:id="btnClose" onAction="#handleClose" prefWidth="150.0" style="-fx-background-color: #1f2937; -fx-text-fill: white; -fx-font-family: 'Segoe UI', sans-serif; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 6; -fx-cursor: hand;" text="Dismiss Receipt">
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Button>
   </children>
</VBox>