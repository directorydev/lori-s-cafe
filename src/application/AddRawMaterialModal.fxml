<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" styleClass="form-container" stylesheets="@application.css" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.InventoryController">
    <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>

    <VBox spacing="5">
        <Label text="Add New Raw Material" styleClass="header-title" />
        <Label text="Track stock levels for cafe ingredients" styleClass="header-subtitle" />
    </VBox>

    <VBox spacing="15">
        <VBox spacing="8">
            <Label text="Material Name *" styleClass="input-label" />
            <TextField fx:id="rawNameInput" promptText="e.g., Full Cream Milk" styleClass="custom-input" />
        </VBox>
        <HBox spacing="15">
            <VBox HBox.hgrow="ALWAYS" spacing="8">
                <Label text="Initial Stock" styleClass="input-label" />
                <TextField fx:id="rawStockInput" promptText="0.0" styleClass="custom-input" />
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="8">
                <Label text="Unit" styleClass="input-label" />
                <ComboBox fx:id="unitCombo" maxWidth="Infinity" styleClass="custom-input" />
            </VBox>
        </HBox>
        <VBox spacing="8">
            <Label text="Min. Stock Level" styleClass="input-label" />
            <TextField fx:id="minStockInput" promptText="Notify when below this amount" styleClass="custom-input" />
        </VBox>
    </VBox>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Cancel" styleClass="secondary-btn" onAction="#handleCloseModal"/>
        <Button text="Add Material" styleClass="primary-btn" onAction="#saveRawMaterial" />
    </HBox>
</VBox>