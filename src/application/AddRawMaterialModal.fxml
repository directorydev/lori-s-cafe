<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0" styleClass="main-bg" stylesheets="@application.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.InventoryController">
   <children>
      <Label text="Add New Raw Material" styleClass="header-title" />
      
      <VBox spacing="15.0">
         <children>
            <VBox spacing="5.0">
               <Label text="Material Name" styleClass="input-label" />
               <TextField fx:id="rawNameInput" promptText="e.g., Full Cream Milk" styleClass="custom-input" />
            </VBox>
            <HBox spacing="15.0">
               <VBox HBox.hgrow="ALWAYS">
                  <Label text="Measurement Unit" styleClass="input-label" />
                  <ComboBox fx:id="unitCombo" promptText="Select Unit" maxWidth="Infinity" styleClass="custom-input" />
               </VBox>
               <VBox HBox.hgrow="ALWAYS">
                  <Label text="Current Stock" styleClass="input-label" />
                  <TextField fx:id="rawStockInput" promptText="0.0" styleClass="custom-input" />
               </VBox>
            </HBox>
         </children>
      </VBox>

      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button onAction="#handleCloseModal" styleClass="secondary-btn" text="Cancel" />
            <Button onAction="#saveRawMaterial" styleClass="primary-btn" text="Add Material" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>
</VBox>